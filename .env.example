# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- OpenAI ---
# API key used to classify tickets. If omitted, the app falls back to
# keyword-based heuristics instead of calling OpenAI.
OPENAI_API_KEY=
# Chat model used for classification (must support JSON response_format).
OPENAI_MODEL=gpt-4o-mini

# --- Flask ---
# Session signing key. REQUIRED when FLASK_ENV=production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=
# Set to "production" to disable the debug server and harden cookies.
# Leave unset/empty for local development.
FLASK_ENV=
# Port to bind (default 5000).
PORT=5000

# --- Database ---
# SQLAlchemy connection string. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///tickets.db

# --- Admin login ---
# Preferred: a Werkzeug password hash. Generate with:
#   python scripts/make_admin_hash.py
ADMIN_PASSWORD_HASH=
# Dev-only alternative: a plain password, hashed at runtime.
# If neither is set, admin login is disabled.
ADMIN_PASSWORD=
# Admin session lifetime in hours (default 1).
SESSION_HOURS=1

# --- Pagination (optional) ---
TICKETS_PER_PAGE=10
ADMIN_TICKETS_PER_PAGE=15
FIXED_PER_PAGE=15
